# PostgreSQL
DATABASE_URL=postgresql://user:password@host:5432/auth_service

# JWT
AUTH_SECRET=CHANGE_ME_TO_RANDOM_64_CHARS

# Адрес самого auth-сервиса
AUTH_URL=http://localhost:3000

# Адрес приложения, куда отправлять после подтверждения почты
APP_URL=http://localhost:3001

# SMTP
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASSWORD=
SMTP_FROM=noreply@example.com

# JWT
JWT_EXPIRES=15m
REFRESH_EXPIRES=30d
